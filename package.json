{
  "name": "poolease",
  "version": "0.1.0",
  "private": true,
  "homepage": ".",
  "main": "main.js",
  "description": "Poolease Application",
  "author": "Mabson",
  "scripts": {
    "start": "cross-env PORT=3002 react-scripts start",
    "build": "react-scripts build",
    "start-electron": "concurrently \"npm run start\" \"wait-on http://localhost:3002 && electron .\"",
    "pack": "electron-builder --dir",
    "dist": "electron-builder"
  },
  "build": {
    "appId": "com.example.poolease",
    "files": [
      "build/**/*",
      "main.js",
      "config.js",
      "public/**/*" 
    ],
    "directories": {
      "buildResources": "assets"
    },
    "win": {
      "target": "nsis",
      "icon": "build/icon.ico"
    },
    "mac": {
      "target": "dmg",
      "icon": "build/icon.icns"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true
    }
  },
  "dependencies": {
    "@testing-library/jest-dom": "^5.16.5",
    "@testing-library/react": "^13.4.0",
    "@testing-library/user-event": "^13.5.0",
    "@types/jest": "^29.5.0",
    "@types/node": "^16.11.14",
    "@types/react": "^18.0.28",
    "@types/react-dom": "^18.0.11",
    "cross-env": "^7.0.3",
    "multer": "^1.4.5-lts.1",
    "prop-types": "^15.8.1",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-icons": "^5.2.1",
    "react-modal": "^3.16.1",
    "react-router-dom": "^6.2.1",
    "react-scripts": "5.0.1",
    "react-slick": "^0.30.2",
    "react-swipeable": "^7.0.1",
    "react-tooltip": "^5.27.1",
    "slick-carousel": "^1.8.1",
    "styled-components": "^6.1.11",
    "web-vitals": "^2.1.4",
    "sqlite3": "^5.0.11",  
    "sqlite": "^5.0.0"
  },
  "devDependencies": {
    "autoprefixer": "^10.4.8",
    "concurrently": "^8.2.2",
    "electron": "^31.2.0",
    "electron-builder": "^23.0.0",
    "postcss": "^8.4.16",
    "tailwindcss": "^3.1.8",
    "wait-on": "^7.2.0",
    "@babel/plugin-proposal-private-property-in-object": "^7.16.7"
  },
  "eslintConfig": {
    "root": true
  },
  "browserslist": {
    "production": [
      ">0.2%",
      "not dead",
      "not op_mini all"
    ],
    "development": [
      "last 1 chrome version",
      "last 1 firefox version",
      "last 1 safari version"
    ]
  }
}
